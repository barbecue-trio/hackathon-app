{
  "compilerOptions": {
    "module": "commonjs",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "target": "ES2022",
    "skipLibCheck": true,
    "baseUrl": ".",
    "typeRoots": ["node_modules/@types", "../types"],
    "paths": {
      "@/*": ["../types/*"]
    }
  },
  "compileOnSave": true,
  "include": ["src/**/*", "../types/**/*"],
  "exclude": ["lib"]
}
